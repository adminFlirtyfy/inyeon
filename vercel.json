{
  "version": 2,
   "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/support", "dest": "/support.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/account", "dest": "/account-management.html" },
    { "src": "/account-management", "dest": "/account-management.html" },
    { "src": "/open-source", "dest": "/open-source.html" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/app-logo.jpg", "dest": "/public/app-logo.jpg" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/googleaed1d32c1fbbd602.html", "dest": "/public/googleaed1d32c1fbbd602.html" }
  ]
}
